# Loaded by dotenvy::dotenv() in main.rs when you `cargo run` from /workspace/api.
# Gitignored — never commit real secrets. Production values go into Fly secrets.
DATABASE_URL=postgres://fira:fira@postgres:5432/fira
RUST_LOG=info,sqlx=warn,tower_http=info
# --- Auth ---
# Google OAuth client (Web application). Same client works for dev + prod —
# both URLs must be registered in the GCP console under this client.
GOOGLE_CLIENT_ID=xxxx
GOOGLE_CLIENT_SECRET=xxxx
# Where Google sends the user back. Must EXACTLY match one of the redirect
# URIs registered in the GCP console.
OAUTH_REDIRECT_URL=http://localhost:5173/api/auth/google/callback
# Where the API redirects the browser after a successful login.
APP_BASE_URL=http://localhost:5173
# 1 in production (HTTPS); 0 in dev (localhost over HTTP). Setting Secure
# cookies on http://localhost would silently fail.
COOKIE_SECURE=0
# Enables /auth/dev-login?email=... — bypasses Google for the seeded users.
# Leave OFF for production.
DEV_AUTH=1